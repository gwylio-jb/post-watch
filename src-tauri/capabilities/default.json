{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Post_Watch desktop permissions — HTTP fetch + external URL opening",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    },
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
